/// List all users
pub fn query_list_users(db: DB) -> Array[ListUsersRow] {
  let sql = "SELECT id, name, email FROM users"
  let _ = db.query(sql)
  []
}

/// Get user by ID
pub fn query_get_user(db: DB, id: Int) -> Option[GetUserRow] {
  let sql = "SELECT id, name, email FROM users WHERE id = $1"
  let _ = db.query(sql)
