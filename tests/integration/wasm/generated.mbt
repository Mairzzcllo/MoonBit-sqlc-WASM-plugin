/// users table
pub struct Users {
  id: Int
  name: String
  /// user email address
  email: Option[String]
}

/// Decode a Row into a Users
pub fn Users::decode(row: Row) -> Users {
  { id: try @string.parse_int(row.get(0)) catch { _ => 0 }, name: row.get(1), email: Some(row.get(2)) }
}

pub enum UserRole {
  Admin
  Editor
  Viewer
}

