/// DB runtime stub (mirrors runtime/db.mbt for compilation testing).
pub struct DB {
  exec_fn : (String, Array[Value]) -> Result[Int64, DBError]
  execrows_fn : (String, Array[Value]) -> Result[Int64, DBError]
  query_fn : (String, Array[Value]) -> Result[RowIter, DBError]
  query_row_fn : (String, Array[Value]) -> Result[Row, DBError]
  begin_fn : (() -> Result[Transaction, DBError])
  copyfrom_fn : (String, Array[Value]) -> Result[Int64, DBError]
  batch_fn : (String, Array[Value]) -> Result[Int64, DBError]
  execlastid_fn : (String, Array[Value]) -> Result[Int64, DBError]
}

pub struct Transaction {
  exec_fn : (String, Array[Value]) -> Result[Int64, DBError]
  execrows_fn : (String, Array[Value]) -> Result[Int64, DBError]
  query_fn : (String, Array[Value]) -> Result[RowIter, DBError]
  query_row_fn : (String, Array[Value]) -> Result[Row, DBError]
  commit_fn : (() -> Result[Unit, DBError])
  rollback_fn : (() -> Result[Unit, DBError])
}

pub fn DB::exec(self: DB, sql: String, params: Array[Value]) -> Result[Int64, DBError] { (self.exec_fn)(sql, params) }
pub fn DB::execrows(self: DB, sql: String, params: Array[Value]) -> Result[Int64, DBError] { (self.execrows_fn)(sql, params) }
pub fn DB::query(self: DB, sql: String, params: Array[Value]) -> Result[RowIter, DBError] { (self.query_fn)(sql, params) }
pub fn DB::query_row(self: DB, sql: String, params: Array[Value]) -> Result[Row, DBError] { (self.query_row_fn)(sql, params) }

/// Row runtime stub (mirrors runtime/row.mbt for compilation testing).
pub struct Row {
  get_fn : (Int) -> String
  null_mask : Array[Bool]
  col_names : Array[String]
  num_cols : Int
}

pub fn Row::new(get_fn: (Int) -> String, null_mask: Array[Bool]) -> Row {
  { get_fn: get_fn, null_mask: null_mask, col_names: [], num_cols: null_mask.length() }
}

pub fn Row::get(self: Row, index: Int) -> String { (self.get_fn)(index) }

pub fn Row::is_null(self: Row, index: Int) -> Bool {
  index >= 0 && index < self.null_mask.length() && self.null_mask[index]
}

pub fn Row::index_of(_self: Row, _name: String) -> Result[Int, DBError] { Ok(0) }

pub fn Row::get_int64(_self: Row, _index: Int) -> Result[Int64, DBError] { Ok(0L) }
pub fn Row::get_string(self: Row, index: Int) -> Result[String, DBError] { Ok(self.get(index)) }
pub fn Row::get_datetime(_self: Row, _index: Int) -> Result[DateTime, DBError] { Ok(DateTime::new("")) }

/// RowIter runtime stub (mirrors runtime/row_iter.mbt for compilation testing).
pub struct RowIter {
  rows : Array[Row]
}

pub fn RowIter::new(rows: Array[Row]) -> RowIter { { rows: rows } }
pub fn RowIter::collect(self: RowIter) -> Result[Array[Row], DBError] { Ok(self.rows) }
pub fn RowIter::collect_limited(self: RowIter, _max_rows: Int) -> Result[Array[Row], DBError] { Ok(self.rows) }

/// Value runtime stub for compilation testing.
pub enum Value { Int64(Int64); String(String) }

/// DateTime stub — matches runtime/value.mbt.
pub struct DateTime { value: String }

pub fn DateTime::new(value: String) -> DateTime { { value: value } }

/// ExecResult stub — matches runtime/value.mbt.
pub struct ExecResult { last_insert_id: Int64; rows_affected: Int64 }

pub fn ExecResult::new(last_insert_id: Int64, rows_affected: Int64) -> ExecResult {
  { last_insert_id: last_insert_id, rows_affected: rows_affected }
}

/// DBError stub.
pub enum DBError { ConnectionError(String); QueryError(String); TypeError(String); NoRows; ColumnNotFound(String); TooManyRows(Int, String); }

pub struct User {
  id: Int64
  name: String
  email: String
  created_at: DateTime
}

pub fn User::decode(row: Row) -> Result[User, DBError] {
  match row.index_of("id") {
    Ok(_idx_0) => match row.get_int64(_idx_0) {
      Ok(id) => match row.index_of("name") {
        Ok(_idx_1) => match row.get_string(_idx_1) {
          Ok(name) => match row.index_of("email") {
            Ok(_idx_2) => match row.get_string(_idx_2) {
              Ok(email) => match row.index_of("created_at") {
                Ok(_idx_3) => match row.get_datetime(_idx_3) {
                  Ok(created_at) => Ok({ id: id, name: name, email: email, created_at: created_at })
                  Err(e) => Err(e)
                }
                Err(e) => Err(e)
              }
              Err(e) => Err(e)
            }
            Err(e) => Err(e)
          }
          Err(e) => Err(e)
        }
        Err(e) => Err(e)
      }
      Err(e) => Err(e)
    }
    Err(e) => Err(e)
  }
}

