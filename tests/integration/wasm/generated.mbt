/// List all users
pub fn query_list_users(db: DB) -> Result[Array[ListUsersRow], DBError] {
  let sql = "SELECT id, name, email FROM users"
  let params = []
  match db.query(sql, params) {
    Ok(iter) => match iter.collect() {
      Ok(rows) => {
        let result = []
        for row in rows {
          match ListUsersRow::decode(row) {
            Ok(v) => result.push(v)
            Err(e) => return Err(e)
          }
        }
        Ok(result)
      }
      Err(e) => Err(e)
    }
    Err(e) => Err(e)
  }
}

/// Get user by ID
pub fn query_get_user(db: DB, id: Int64) -> Result[GetUserRow, DBError] {
  let sql = "SELECT id, name, email FROM users WHERE id = $1"
  let params = [Int64(id)]
  match db.query(sql, params) {
    Ok(rows) => match rows.collect_limited(2) {
      Ok(collected) => match collected.length() {
        0 => Err(NoRows)
        1 => GetUserRow::decode(collected[0])
        _ => Err(TooManyRows(collected.length(), sql))
      }
      Err(TooManyRows(n, _)) => Err(TooManyRows(n, sql))
      Err(e) => Err(e)
    }
    Err(e) => Err(e)
  }
}

pub fn query_delete_user(db: DB, id: Int64) -> Result[ExecResult, DBError] {
  let sql = "DELETE FROM users WHERE id = $1"
  let params = [Int64(id)]
  match db.exec(sql, params) {
    Ok(n) => Ok({ last_insert_id: 0L, rows_affected: n })
    Err(e) => Err(e)
  }
}
